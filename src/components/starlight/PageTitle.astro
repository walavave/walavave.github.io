---
const { entry } = Astro.locals.starlightRoute;
const title = entry.data.title;
const isSplash = entry.data.template === 'splash';
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const markdownUrl = `${pathname}index.md`;
const pageTitleId = '_top';
const labels = {
	copy: Astro.locals.t('pageTitle.copy'),
	copied: Astro.locals.t('pageTitle.copied'),
	view: Astro.locals.t('pageTitle.view'),
	chatgpt: Astro.locals.t('pageTitle.chatgpt'),
	claude: Astro.locals.t('pageTitle.claude'),
	lechat: Astro.locals.t('pageTitle.lechat'),
	grok: Astro.locals.t('pageTitle.grok'),
	openMenu: Astro.locals.t('pageTitle.openMenu'),
	assistantPrompt: Astro.locals.t('pageTitle.assistantPrompt'),
};

const copyIcon = `
	<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<rect x="8" y="8" width="12" height="12" rx="2" />
		<path d="M6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
	</svg>
`;

const markdownIcon = `
	<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
		<path d="m7 15 2.5-3L12 15V9" />
		<path d="m16 9 3 3-3 3" />
	</svg>
`;

const assistantIcon = `
	<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="m12 3 1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6Z" />
		<path d="m18 14 .8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8Z" />
	</svg>
`;

const moreIcon = `
	<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="5" r="1.5" />
		<circle cx="12" cy="12" r="1.5" />
		<circle cx="12" cy="19" r="1.5" />
	</svg>
`;

const menuItems = [
	{ id: 'copy', label: labels.copy, icon: copyIcon },
	{ id: 'view', label: labels.view, icon: markdownIcon },
	{ id: 'chatgpt', label: labels.chatgpt, icon: assistantIcon },
	{ id: 'claude', label: labels.claude, icon: assistantIcon },
	{ id: 'lechat', label: labels.lechat, icon: assistantIcon },
	{ id: 'grok', label: labels.grok, icon: assistantIcon },
] as const;

const primaryAction = menuItems[0];
---

<div class="paper-page-title-block">
	<div class="paper-page-title-row">
		<h1 id={pageTitleId}>{title}</h1>
	</div>
	{!isSplash && (
		<div class="paper-page-title-actions">
			<div
				class="paper-contextual-menu"
				data-paper-contextual-menu
				data-markdown-url={markdownUrl}
				data-copied-label={labels.copied}
				data-assistant-prompt={labels.assistantPrompt}
				data-open="false"
			>
				<button type="button" class="paper-contextual-main-action" data-action={primaryAction.id}>
					<span class="paper-contextual-icon" set:html={primaryAction.icon} />
					<span data-button-label>{primaryAction.label}</span>
				</button>
				<button
					type="button"
					class="paper-contextual-trigger"
					data-contextual-trigger
					aria-label={labels.openMenu}
					aria-expanded="false"
					aria-haspopup="menu"
				>
					<span class="paper-contextual-icon" set:html={moreIcon} />
				</button>
				<div class="paper-contextual-dropdown" data-contextual-dropdown hidden>
					{
						menuItems.map((item) => (
							<button type="button" class="paper-contextual-menu-item" data-action={item.id} role="menuitem">
								<span class="paper-contextual-icon" set:html={item.icon} />
								<span data-button-label>{item.label}</span>
							</button>
						))
					}
				</div>
			</div>
		</div>
	)}
</div>

<script is:inline>
	const menuSelector = '[data-paper-contextual-menu]';

	async function fetchMarkdown(markdownUrl) {
		const response = await fetch(markdownUrl, {
			headers: {
				accept: 'text/markdown,text/plain;q=0.9,*/*;q=0.8',
			},
		});
		if (!response.ok) {
			throw new Error(`Failed to load markdown: ${response.status}`);
		}
		return response.text();
	}

	function fallbackCopy(text) {
		const textarea = document.createElement('textarea');
		textarea.value = text;
		textarea.setAttribute('readonly', 'true');
		textarea.style.position = 'fixed';
		textarea.style.inset = '-9999px';
		document.body.append(textarea);
		textarea.select();
		document.execCommand('copy');
		textarea.remove();
	}

	async function copyMarkdown(markdownUrl) {
		const markdown = await fetchMarkdown(markdownUrl);
		if (navigator.clipboard?.write && typeof ClipboardItem !== 'undefined') {
			const clipboardItem = new ClipboardItem({
				'text/plain': new Blob([markdown], { type: 'text/plain' }),
			});
			await navigator.clipboard.write([clipboardItem]);
			return;
		}
		if (navigator.clipboard?.writeText) {
			await navigator.clipboard.writeText(markdown);
			return;
		}
		fallbackCopy(markdown);
	}

	function buildAssistantUrl(actionId, pageUrl) {
		const menu = document.querySelector(menuSelector);
		const promptTemplate =
			menu instanceof HTMLElement
				? menu.dataset.assistantPrompt || 'Read from {{url}} so I can ask questions about it.'
				: 'Read from {{url}} so I can ask questions about it.';
		const query = encodeURIComponent(promptTemplate.replace('{{url}}', pageUrl));
		switch (actionId) {
			case 'chatgpt':
				return `https://chat.openai.com/?q=${query}`;
			case 'claude':
				return `https://claude.ai/new?q=${query}`;
			case 'lechat':
				return `https://chat.mistral.ai/chat?q=${query}`;
			case 'grok':
				return `https://grok.com/?q=${query}`;
			default:
				return pageUrl;
		}
	}

	function setMenuOpen(menu, open) {
		menu.dataset.open = open ? 'true' : 'false';
		const trigger = menu.querySelector('[data-contextual-trigger]');
		const dropdown = menu.querySelector('[data-contextual-dropdown]');
		if (trigger) {
			trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
		}
		if (dropdown) {
			dropdown.hidden = !open;
		}
	}

	function flashCopied(menu) {
		const copiedLabel = menu.dataset.copiedLabel || 'Copied!';
		menu.querySelectorAll('[data-action="copy"] [data-button-label]').forEach((label) => {
			const element = label;
			const originalLabel = element.dataset.originalLabel || element.textContent || '';
			element.dataset.originalLabel = originalLabel;
			element.textContent = copiedLabel;
			window.setTimeout(() => {
				element.textContent = element.dataset.originalLabel || originalLabel;
			}, 2000);
		});
	}

	async function runAction(menu, actionId) {
		const markdownUrl = menu.dataset.markdownUrl;
		if (!markdownUrl) return;

		if (actionId === 'copy') {
			await copyMarkdown(markdownUrl);
			flashCopied(menu);
			return;
		}

		if (actionId === 'view') {
			window.open(markdownUrl, '_blank', 'noopener,noreferrer');
			return;
		}

		window.open(
			buildAssistantUrl(actionId, window.location.href),
			'_blank',
			'noopener,noreferrer'
		);
	}

	function initializeMenu(menu) {
		if (menu.dataset.enhanced === 'true') return;
		menu.dataset.enhanced = 'true';

		const trigger = menu.querySelector('[data-contextual-trigger]');
		if (trigger) {
			trigger.addEventListener('click', (event) => {
				event.stopPropagation();
				setMenuOpen(menu, menu.dataset.open !== 'true');
			});
		}

		menu.querySelectorAll('[data-action]').forEach((button) => {
			button.addEventListener('click', async () => {
				try {
					await runAction(menu, button.dataset.action || '');
				} catch (error) {
					console.error('Contextual menu action failed.', error);
				} finally {
					setMenuOpen(menu, false);
				}
			});
		});
	}

	function initializeMenus() {
		document.querySelectorAll(menuSelector).forEach((menu) => initializeMenu(menu));
	}

	if (!window.__paperContextualMenuBound) {
		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node)) return;
			document.querySelectorAll(`${menuSelector}[data-open="true"]`).forEach((menu) => {
				if (!menu.contains(event.target)) {
					setMenuOpen(menu, false);
				}
			});
		});

		document.addEventListener('keydown', (event) => {
			if (event.key !== 'Escape') return;
			document.querySelectorAll(`${menuSelector}[data-open="true"]`).forEach((menu) => {
				setMenuOpen(menu, false);
			});
		});

		window.__paperContextualMenuBound = true;
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initializeMenus, { once: true });
	} else {
		initializeMenus();
	}

	document.addEventListener('astro:page-load', initializeMenus);
</script>

<style>
	@layer starlight.core {
		.paper-page-title-block {
			display: grid;
			gap: 0.75rem;
		}

		.paper-page-title-row {
			display: block;
		}

		.paper-page-title-row > h1 {
			margin-top: 1rem;
			font-size: var(--sl-text-h1);
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
			flex: 1 1 18rem;
			min-width: 0;
		}

		.paper-page-title-actions {
			display: flex;
			align-items: flex-start;
			margin-top: -0.1rem;
		}

		.paper-contextual-menu {
			position: relative;
			display: inline-flex;
			align-items: stretch;
		}

		.paper-contextual-main-action,
		.paper-contextual-trigger,
		.paper-contextual-menu-item {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.45rem;
			border: 1px solid var(--sl-color-hairline);
			background: color-mix(in srgb, var(--sl-color-black) 15%, var(--sl-color-bg));
			color: var(--sl-color-white);
			font: inherit;
			font-size: var(--sl-text-sm);
			line-height: 1.4;
			cursor: pointer;
			transition:
				background-color 0.2s ease,
				border-color 0.2s ease,
				transform 0.2s ease;
		}

		.paper-contextual-main-action,
		.paper-contextual-trigger {
			height: 1.8rem;
			padding: 0 0.55rem;
		}

		.paper-contextual-main-action {
			border-start-start-radius: 0.5rem;
			border-end-start-radius: 0.5rem;
			border-inline-end: none;
		}

		.paper-contextual-trigger {
			width: 2rem;
			padding: 0;
			border-start-end-radius: 0.5rem;
			border-end-end-radius: 0.5rem;
		}

		.paper-contextual-main-action:hover,
		.paper-contextual-trigger:hover,
		.paper-contextual-menu-item:hover {
			background: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-bg));
			border-color: color-mix(in srgb, var(--sl-color-accent) 45%, var(--sl-color-hairline));
		}

		.paper-contextual-main-action:active,
		.paper-contextual-trigger:active,
		.paper-contextual-menu-item:active {
			transform: scale(0.985);
		}

		.paper-contextual-main-action:focus-visible,
		.paper-contextual-trigger:focus-visible,
		.paper-contextual-menu-item:focus-visible {
			outline: 2px solid var(--sl-color-accent);
			outline-offset: 2px;
		}

		.paper-contextual-icon {
			display: inline-flex;
			width: 0.875rem;
			height: 0.875rem;
			flex: 0 0 0.875rem;
		}

		.paper-contextual-icon :global(svg) {
			width: 100%;
			height: 100%;
		}

		.paper-contextual-main-action [data-button-label],
		.paper-contextual-menu-item [data-button-label] {
			white-space: nowrap;
		}

		.paper-contextual-dropdown {
			position: absolute;
			inset-block-start: calc(100% + 0.5rem);
			inset-inline-end: 0;
			display: flex;
			min-width: 13rem;
			flex-direction: column;
			gap: 0.2rem;
			padding: 0.25rem;
			border: 1px solid var(--sl-color-hairline);
			border-radius: 0.65rem;
			background: var(--sl-color-bg);
			z-index: calc(var(--sl-z-index-menu) + 1);
		}

		.paper-contextual-menu-item {
			width: 100%;
			justify-content: flex-start;
			border: none;
			border-radius: 0.45rem;
			padding: 0.35rem 0.5rem;
			text-align: left;
		}

		@media (max-width: 72rem) {
			.paper-contextual-dropdown {
				inset-inline-start: 0;
				inset-inline-end: auto;
			}
		}

		@media (max-width: 40rem) {
			.paper-contextual-main-action [data-button-label] {
				display: none;
			}

			.paper-contextual-main-action {
				padding-inline: 0.55rem;
			}
		}
	}
</style>
