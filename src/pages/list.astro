---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import PaperStatusBoard from '../components/openstatus/PaperStatusBoard';

function normalizeEntryField(value) {
	return (Array.isArray(value) ? Object.assign({}, ...value) : value) ?? {};
}

function normalizeValues(value) {
	if (!value) return [];
	return (Array.isArray(value) ? value : [value])
		.flatMap((entry) => entry.split(','))
		.map((entry) => entry.trim())
		.filter(Boolean);
}

const papers = (await getCollection('docs'))
	.filter((entry) => entry.id.startsWith('papers/'))
	.map((entry) => {
		const links = normalizeEntryField(entry.data.link);
		const platform = normalizeEntryField(entry.data.platform);
		return {
			id: entry.id,
			title: entry.data.title,
			href: `/${entry.id}/`,
			links: [
				{ label: 'arXiv', href: links.arxiv },
				{ label: 'Website', href: links.website },
				{ label: 'YouTube', href: links.youtube },
				{ label: 'GitHub', href: links.github },
			],
			train: normalizeValues(platform.train),
			simulate: normalizeValues(platform.simulate),
			deploy: normalizeValues(platform.deploy),
			tags: normalizeValues(entry.data.tags),
		};
	})
	.sort((a, b) => a.title.localeCompare(b.title, 'zh-Hans-CN'));
---

<StarlightPage
	frontmatter={{
		title: 'Paper Status',
		description: 'Paper index rendered as a custom interactive status table built with React and TanStack Table.',
		template: 'splash',
		editUrl: false,
		hero: {
			title: 'Paper Status',
			tagline: 'Papers displayed in a custom status table with status indicators, platform columns, and tag filtering.',
		},
	}}
>
	<div class="paper-status-board-wrapper not-content">
		<PaperStatusBoard client:load papers={papers} />
	</div>
</StarlightPage>

<style>
	/* Lift Starlight's content-width constraint so the data table
	   + filter sidebar fits. Only affects this page. */
	.sl-container:has(.paper-status-board-wrapper) {
		max-width: none;
	}
	.paper-status-board-wrapper {
		overflow-x: auto;
	}
</style>
